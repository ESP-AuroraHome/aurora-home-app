{
  "name": "aurora-home-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "biome check . && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prisma-seed-fake-data": "tsx prisma/seedFakeData.ts",
    "test-mqtt": "tsx scripts/test-mqtt-subscribe.ts",
    "test-warmup-reset": "tsx scripts/test-warmup-reset.ts",
    "test-warmup-fill": "tsx scripts/test-warmup-fill.ts",
    "prisma-clear-data": "tsx prisma/clearData.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "simulate": "node scripts/simulate-sensors.mjs",
    "simulate:co2": "node scripts/simulate-sensors.mjs --anomaly co2",
    "simulate:temp": "node scripts/simulate-sensors.mjs --anomaly temp",
    "simulate:hum": "node scripts/simulate-sensors.mjs --anomaly hum",
    "simulate:sudden": "node scripts/simulate-sensors.mjs --anomaly sudden",
    "seed:7days": "tsx scripts/seed-7days.ts",
    "seed:7days:clear": "tsx scripts/seed-7days.ts --clear",
    "test:iaq": "node scripts/test-iaq.mjs --level all",
    "test:iaq:excellent": "node scripts/test-iaq.mjs --level excellent",
    "test:iaq:good": "node scripts/test-iaq.mjs --level bon",
    "test:iaq:moderate": "node scripts/test-iaq.mjs --level moyen",
    "test:iaq:poor": "node scripts/test-iaq.mjs --level mauvais",
    "prepare": "husky"
  },
  "dependencies": {
    "@dicebear/collection": "^9.2.4",
    "@dicebear/core": "^9.2.4",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/mqtt": "^0.0.34",
    "better-auth": "^1.3.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.554.0",
    "mqtt": "^5.15.0",
    "next": "16.0.3",
    "next-intl": "^4.5.8",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@faker-js/faker": "^9.9.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "optionalDependencies": {
    "i2c-bus": "^5.2.3"
  }
}
